# HuggingFace token (for gated model downloads and Hub push)
HF_TOKEN=

# Weights & Biases API key (optional, for training logging)
WANDB_API_KEY=

# OpenRouter/OpenAI-compatible baseline (optional, for comparison evaluation)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-coder

# Direct OpenAI fallback
OPENAI_API_KEY=

# vLLM serving configuration
VLLM_PORT=8000
MODEL_PATH=./outputs/awq-model
SERVED_MODEL_NAME=qwen2.5-7b-tool-call
TENSOR_PARALLEL=1
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.90
