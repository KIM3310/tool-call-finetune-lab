# HuggingFace token (for gated model downloads and Hub push)
HF_TOKEN=

# Weights & Biases API key (optional, for training logging)
WANDB_API_KEY=

# OpenAI API key (optional, for GPT-4o-mini comparison evaluation)
OPENAI_API_KEY=

# vLLM serving configuration
VLLM_PORT=8000
MODEL_PATH=./outputs/awq-model
SERVED_MODEL_NAME=qwen2.5-7b-tool-call
TENSOR_PARALLEL=1
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.90
